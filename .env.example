TAG=latest
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=change-me
#PG_DATABASE_HOST=db
#PG_DATABASE_PORT=5432
#REDIS_URL=redis://redis:6379

SERVER_URL=http://localhost:3000

# Use openssl rand -base64 32 for each secret
ENCRYPTION_KEY=change-me
# FALLBACK_ENCRYPTION_KEY= # set to the previous ENCRYPTION_KEY during a rotation
# APP_SECRET= # legacy: only required for instances that pre-date ENCRYPTION_KEY

STORAGE_TYPE=local
# STORAGE_S3_REGION=eu-west3
# STORAGE_S3_NAME=my-bucket
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# Chatwoot
CHATWOOT_SECRET_KEY_BASE=change-me

# Fill after Chatwoot and Twenty are running.
CHATWOOT_API_TOKEN=
TWENTY_API_KEY=

# Middleware
MIDDLEWARE_WEBHOOK_SECRET=change-me

